build --@rules_rust//rust/toolchain/channel=nightly

build:size --compilation_mode=opt
build:size --copt=-Os
build:size --@rules_rust//rust/settings:extra_rustc_flag=-Copt-level=s
build:size --@rules_rust//rust/settings:extra_rustc_flag=-Cstrip=symbols
build:size --@rules_rust//rust/settings:lto=fat
